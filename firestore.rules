rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && role in getUserData().roles;
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false; // Never delete users
    }

    // ── Drives ────────────────────────────────────────────────────────────────

    match /drives/{driveId} {
      allow read: if isAuthenticated();

      allow create: if hasRole('organizer')
        && request.resource.data.organizerId == request.auth.uid;

      allow update: if isAuthenticated() && (
        // Organizer can update their own drive
        (hasRole('organizer') && resource.data.organizerId == request.auth.uid)
        ||
        // Any authenticated user can join/leave (update volunteersJoined only)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['volunteersJoined']))
      );

      allow delete: if hasRole('organizer')
        && resource.data.organizerId == request.auth.uid
        && resource.data.status == 'upcoming';
    }

    // ── Waste Listings ────────────────────────────────────────────────────────

    match /wasteListings/{listingId} {
      allow read: if isAuthenticated();

      allow create: if hasRole('organizer')
        && request.resource.data.organizerId == request.auth.uid;

      allow update: if isAuthenticated() && (
        // Organizer updates their own listing
        (hasRole('organizer') && resource.data.organizerId == request.auth.uid)
        ||
        // Startup can mark as pending/sold (status change only)
        (hasRole('startup') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      );

      allow delete: if hasRole('organizer')
        && resource.data.organizerId == request.auth.uid
        && resource.data.status == 'available';
    }

    // ── Startup Stores ────────────────────────────────────────────────────────

    match /startupStores/{storeId} {
      allow read: if isAuthenticated();

      allow create: if hasRole('startup')
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if hasRole('startup')
        && resource.data.ownerId == request.auth.uid;

      allow delete: if false;
    }

    // ── Products ──────────────────────────────────────────────────────────────

    match /products/{productId} {
      allow read: if isAuthenticated();

      allow create: if hasRole('startup') && (
        get(/databases/$(database)/documents/startupStores/$(request.resource.data.storeId)).data.ownerId
        == request.auth.uid
      );

      allow update: if hasRole('startup') && (
        get(/databases/$(database)/documents/startupStores/$(resource.data.storeId)).data.ownerId
        == request.auth.uid
      );

      allow delete: if hasRole('startup') && (
        get(/databases/$(database)/documents/startupStores/$(resource.data.storeId)).data.ownerId
        == request.auth.uid
      );
    }

    // ── Orders ────────────────────────────────────────────────────────────────

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );

      allow create: if isAuthenticated()
        && request.resource.data.buyerId == request.auth.uid;

      // Only Cloud Functions update order status
      allow update: if false;
      allow delete: if false;
    }

    // ── Proof Photos ──────────────────────────────────────────────────────────

    match /proofPhotos/{photoId} {
      allow read: if isAuthenticated();

      allow create: if hasRole('volunteer')
        && request.resource.data.volunteerId == request.auth.uid;

      allow update: if false; // Only Cloud Functions update AI verification
      allow delete: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow create, delete: if false; // Only Cloud Functions create notifications
    }

    // ── Platform Stats (read-only for clients) ────────────────────────────────

    match /platform/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions write stats
    }
  }
}
